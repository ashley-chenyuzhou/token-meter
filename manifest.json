{
  "manifest_version": 3,
  "name": "Token Meter for Claude",
  "version": "1.0.0",
  "description": "See how many tokens your message and Claude's reply will likely use — before you hit send.",

  "permissions": ["storage"],

  "host_permissions": ["https://claude.ai/*"],

  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": ["base_model.js", "model.js", "content.js"],
      "css": ["widget.css"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "Token Meter"
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
